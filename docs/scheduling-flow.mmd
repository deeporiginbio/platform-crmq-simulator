flowchart TD
    %% Arrival
    Arrival([Job Arrives]) --> CalcScore["Calculate Score (Active Formula)"]
    CalcScore --> PriorityQueue[("Priority Queue")]

    %% Scheduling
    SchedulerTick(("Scheduler Tick")) --> EvalJobs["Evaluate Top-N Jobs"]
    PriorityQueue -.-> EvalJobs

    EvalJobs --> Gate1{"Gate 1: Org Quota"}

    %% Gate 1 Check
    Gate1 -- "Exceeds Quota" --> Skip1["Skip Job (Queue not blocked)"]
    Skip1 --> EvalNext["Evaluate Next Job"]
    EvalNext --> EvalJobs

    Gate1 -- "Has Room" --> Gate2{"Gate 2: Pool Capacity"}

    %% Gate 2 Check
    Gate2 -- "Lacks Capacity" --> IncSkip["Increment Skip Count"]
    IncSkip --> SkipThreshold{"Skip Count > Threshold?"}

    SkipThreshold -- "No" --> EvalNext
    SkipThreshold -- "Yes" --> ResMode["Enter Reservation Mode"]

    %% Reservation Mode
    ResMode --> Accumulate["Block other jobs & Accumulate Resources"]
    Accumulate --> CheckBackfill{"Small job can backfill?"}
    CheckBackfill -- "Yes" --> DispatchBackfill["Dispatch Backfill Job"]
    CheckBackfill -- "No" --> WaitResources["Wait for Completion"]
    WaitResources -.-> SchedulerTick

    %% Dispatch & Completion
    Gate2 -- "Has Capacity" --> DispatchJob["Dispatch Job"]
    DispatchJob --> Consume["Consume Resources (Duration)"]
    DispatchBackfill --> Consume

    Consume --> JobComplete([Job Completes])
    JobComplete --> Release["Release Resources"]
    Release -.-> SchedulerTick

    %% Styles — Arrival (blue)
    style Arrival fill:#4A90D9,stroke:#2C5F8A,color:#FFFFFF
    style CalcScore fill:#5BA3E6,stroke:#2C5F8A,color:#FFFFFF
    style PriorityQueue fill:#3B7DD8,stroke:#2C5F8A,color:#FFFFFF

    %% Styles — Scheduler Tick (teal)
    style SchedulerTick fill:#1ABC9C,stroke:#148F77,color:#FFFFFF
    style EvalJobs fill:#1ABC9C,stroke:#148F77,color:#FFFFFF

    %% Styles — Gate decisions (amber)
    style Gate1 fill:#F5A623,stroke:#C17D1A,color:#FFFFFF
    style Gate2 fill:#F5A623,stroke:#C17D1A,color:#FFFFFF
    style SkipThreshold fill:#F5A623,stroke:#C17D1A,color:#FFFFFF
    style CheckBackfill fill:#F5A623,stroke:#C17D1A,color:#FFFFFF

    %% Styles — Skip / reject path (red)
    style Skip1 fill:#E74C3C,stroke:#B03A2E,color:#FFFFFF
    style EvalNext fill:#E74C3C,stroke:#B03A2E,color:#FFFFFF
    style IncSkip fill:#E74C3C,stroke:#B03A2E,color:#FFFFFF

    %% Styles — Reservation Mode (purple)
    style ResMode fill:#9B59B6,stroke:#6C3483,color:#FFFFFF
    style Accumulate fill:#9B59B6,stroke:#6C3483,color:#FFFFFF
    style WaitResources fill:#9B59B6,stroke:#6C3483,color:#FFFFFF

    %% Styles — Dispatch & Completion (green)
    style DispatchJob fill:#2ECC71,stroke:#1E8449,color:#FFFFFF
    style DispatchBackfill fill:#2ECC71,stroke:#1E8449,color:#FFFFFF
    style Consume fill:#27AE60,stroke:#1E8449,color:#FFFFFF
    style JobComplete fill:#2ECC71,stroke:#1E8449,color:#FFFFFF
    style Release fill:#27AE60,stroke:#1E8449,color:#FFFFFF
